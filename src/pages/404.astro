---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
---
<Base active="lib" title="Kayıt bulunamadı (404) — ANDA Kimya" description="İstenen sayfa bulunamadı.">
  <div class="ak-wrap ak-page">
    <div class="ak-blockhead ak-blockhead--page">
      <h2 class="ak-h2mono">404 — KAYIT BULUNAMADI</h2>
    </div>
    <div style="padding:56px 20px 72px;max-width:52ch;">
      <h1 class="ak-h1 ak-h1--sm">Bu dosyada böyle bir kayıt yok.</h1>
      <p class="ak-lede">Aradığınız sayfa taşınmış ya da hiç var olmamış olabilir. İndeksten devam edebilirsiniz.</p>
      <div style="display:flex;gap:12px;margin-top:24px;">
        <a class="anda-btn anda-btn--primary anda-btn--md" href="/"><span>Ana sayfa</span><Icon name="arrow-right" size={17} /></a>
        <a class="anda-btn anda-btn--secondary anda-btn--md" href="/urunler"><span>Ürün indeksi</span></a>
      </div>
    </div>
  </div>
</Base>
