---
import Seal from './Seal.astro';
---
<footer class="ak-footer">
  <div class="ak-wrap ak-footer__grid">
    <div class="ak-footer__brand">
      <img src="/assets/anda-logo-white.png" alt="ANDA" class="ak-footer__logo" width="119" height="26" loading="lazy" />
      <p>Beton katkı kimyasalları — PCE su azaltıcı ve kıvam koruyucu.<br />Gebze-Balçık üretim tesisi.</p>
    </div>
    <div class="ak-footer__col">
      <span class="ak-lbl">Dizin</span>
      <a href="/urunler">Ürünler</a>
      <a href="/teknoloji">Teknoloji</a>
      <a href="/kalite">Kalite &amp; Mevzuat</a>
      <a href="/kutuphane">Teknik Kütüphane</a>
    </div>
    <div class="ak-footer__col">
      <span class="ak-lbl">İletişim</span>
      <p>Balçık Mah. 3265 Sok. No:20<br />Gebze / Kocaeli, Türkiye<br /><a href="mailto:info@andakimya.com">info@andakimya.com</a></p>
    </div>
    <div class="ak-footer__seal">
      <Seal size={104} markSrc="/assets/anda-mark-white.png" stroke="rgba(255,255,255,0.85)" dot={false} />
    </div>
  </div>
  <div class="ak-footer__bottom">
    <div class="ak-wrap ak-footer__bottombar">
      <span class="ak-ref">© 2026 ANDA Kimya · Tüm hakları saklıdır</span>
      <span class="ak-ref"><a href="/kvkk">KVKK Aydınlatma</a> · <a href="/kvkk#cerez">Çerez Politikası</a></span>
    </div>
  </div>
</footer>
