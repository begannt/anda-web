---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import products from '../../data/products.json';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}
const { p } = Astro.props;
---
<Base active="index" title={`${p.kod} — ANDA Kimya`} description={p.aciklama}>
  <div class="ak-wrap ak-page">
    <!-- Breadcrumb -->
    <nav class="anda-crumb" aria-label="breadcrumb">
      <a href="/">ANDA</a><span class="sep"><Icon name="chevron-right" size={12} /></span>
      <a href="/urunler">Ürünler</a><span class="sep"><Icon name="chevron-right" size={12} /></span>
      <span>{p.tip}</span><span class="sep"><Icon name="chevron-right" size={12} /></span>
      <span class="cur" aria-current="page">{p.kod}</span>
    </nav>

    <div class="ak-detail__head">
      <div class="ak-detail__id">
        <span class="ak-detail__kod">{p.kod}</span>
        <span class={`anda-status anda-status--${p.tone}`}><span class="d"></span><span>{p.durum}</span></span>
      </div>
      <h1 class="ak-h1 ak-h1--sm">{p.tip}</h1>
      <p class="ak-lede">{p.aciklama}</p>
      <div class="ak-detail__badges">
        <span class="anda-stdbadge"><span class="tick"></span><span>{p.std}</span></span>
        <span class="anda-stdbadge"><span>{p.sinif}</span></span>
      </div>
    </div>

    <div class="ak-detail__grid">
      <div class="ak-detail__main">
        <div class="ak-blockhead">
          <h2 class="ak-h2mono">Öne Çıkan Performans</h2>
          <span class="ak-ref">GÜÇLÜ YANLAR</span>
        </div>
        {p.headline && (
          <div class="ak-headline">
            <span class="v">{p.headline.v}<i>{p.headline.u}</i></span>
          </div>
        )}
        <div class="ak-strengths">
          {p.strengths.map((s) => (
            <div class="ak-strength"><span class="ak-use__tick"></span><span>{s}</span></div>
          ))}
        </div>

        <div class="ak-block" style="border-bottom:0;">
          <div class="ak-blockhead"><h2 class="ak-h2mono">Uygulama Alanları</h2></div>
          <div class="ak-uses">
            {p.uses.map((u) => (
              <div class="ak-use"><span class="ak-use__tick"></span>{u}</div>
            ))}
          </div>
        </div>
      </div>

      <aside class="ak-detail__side">
        <div class="anda-panel">
          <div class="anda-panel__head"><span class="anda-panel__title">Belgeler</span></div>
          <div class="anda-panel__body">
            <p class="ak-side__note">Katalog açık erişimdedir. TDS, SDS/GBF ve COA kontrollü belgelerdir; detaylar için bizimle iletişime geçin.</p>
            <div class="ak-side__actions">
              <span class="anda-btn anda-btn--ghost anda-btn--md anda-btn--full" style="cursor:default;opacity:.7;"><Icon name="file-text" size={17} /><span>Katalog — Yakında</span></span>
              <a class="anda-btn anda-btn--primary anda-btn--md anda-btn--full" href="/iletisim"><Icon name="mail" size={17} /><span>Detaylar için İletişim</span></a>
            </div>
          </div>
        </div>

        <div class="anda-panel">
          <div class="anda-panel__head"><span class="anda-panel__title">Lot İzlenebilirlik</span></div>
          <div class="anda-panel__body">
            <div class="ak-side__kv">
              <div><i>COA</i><b>{p.lot.coa}</b></div>
              <div><i>Üretim</i><b>{p.lot.uretim}</b></div>
              <div><i>Raf ömrü</i><b>{p.lot.raf}</b></div>
              <div><i>Ambalaj</i><b>{p.lot.ambalaj}</b></div>
            </div>
          </div>
        </div>

        <div class="ak-back">
          <a class="anda-btn anda-btn--ghost anda-btn--sm" href="/urunler"><Icon name="arrow-right" size={15} /><span>Ürünlere dön</span></a>
        </div>
      </aside>
    </div>
  </div>
</Base>
