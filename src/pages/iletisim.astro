---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Blueprint from '../components/Blueprint.astro';
---
<Base active="contact" title="Hakkımızda & İletişim — ANDA Kimya" description="ANDA Kimya — Gebze-Balçık'ta 6. nesil PCE beton katkı üreticisi. Teklif, teknik belge ve teknik görüşme talebi. info@andakimya.com">
  <div class="ak-wrap ak-page">
    <div class="ak-blockhead ak-blockhead--page">
      <div>
        <h2 class="ak-h2mono">Hakkımızda & İletişim</h2>
        <p class="ak-page__sub">ANDA'yı tanıyın; teklif, teknik belge veya teknik görüşme için ulaşın.</p>
      </div>
    </div>

    <!-- HAKKIMIZDA -->
    <div class="ak-detail__grid" id="hakkimizda">
      <div class="ak-detail__main">
        <h1 class="ak-h1 ak-h1--sm">Ölçülmüş değer ve belgeyle üretilen beton katkı kimyasalları.</h1>
        <p class="ak-lede" style="max-width:60ch;">ANDA, beton kimyasında faaliyet gösteren bir yapı kimyasalları markasıdır. Güncel kuşak formülasyon teknolojisini Gebze-Balçık üretimiyle Türkiye sahasına taşır; 6. nesil polikarboksilat eter (PCE) beton katkılarını ölçülmüş değer ve belgeyle üretir.</p>
        <p style="font-size:15px;color:var(--text-body);line-height:1.75;max-width:60ch;">Başlangıç odağımız Marmara bölgesi hazır beton üreticileri. Hızlı değil, doğru büyümeyi seçiyoruz: portföyü ölçülü genişletmek, her ürünü standart ve belgeyle çıkarmak, sahada sözün arkasında durmak.</p>
        <div style="display:flex;gap:12px;margin-top:24px;flex-wrap:wrap;">
          <a class="anda-btn anda-btn--secondary anda-btn--md" href="/urunler"><span>Ürünler</span><Icon name="arrow-right" size={17} /></a>
          <a class="anda-btn anda-btn--ghost anda-btn--md" href="/teknoloji"><span>Teknoloji & Kalite</span></a>
        </div>
      </div>
      <aside class="ak-detail__side" style="position:static;">
        <Blueprint kind="akis" />
      </aside>
    </div>

    <!-- İLETİŞİM & TALEP -->
    <div class="ak-blockhead" style="margin-top:56px;"><h2 class="ak-h2mono">İletişim & Talep</h2><span class="ak-ref">TEKLİF · BELGE · GÖRÜŞME</span></div>
    <div class="ak-detail__grid">
      <div class="ak-detail__main">
        <div class="anda-panel">
          <div class="anda-panel__head"><span class="anda-panel__title">Üretim Tesisi</span><span class="anda-panel__meta">GEBZE-BALÇIK</span></div>
          <div class="anda-panel__body">
            <div class="ak-side__kv">
              <div><i>Marka</i><b>ANDA Kimya</b></div>
              <div><i>Tesis</i><b>Gebze-Balçık</b></div>
            </div>
            <address class="not-italic" style="font-style:normal;margin-top:18px;font-size:14px;color:var(--text-body);line-height:1.7;">
              Balçık Mah. 3265 Sok. No:20<br />Gebze / Kocaeli, Türkiye
            </address>
            <p style="margin-top:16px;display:flex;align-items:center;gap:9px;font-size:14px;">
              <Icon name="mail" size={16} /><a href="mailto:info@andakimya.com" style="color:var(--anda-blue);">info@andakimya.com</a>
            </p>
          </div>
        </div>

        <div class="anda-panel" style="margin-top:16px;">
          <div class="anda-panel__head"><span class="anda-panel__title">Talep Tipleri</span></div>
          <div class="anda-panel__body">
            <div class="ak-side__kv" style="grid-template-columns:1fr;gap:12px;">
              <div><i>Teklif</i><b>Ürün ve proje bazlı fiyat teklifi</b></div>
              <div><i>TDS / SDS</i><b>Kontrollü teknik belgeler — talep üzerine</b></div>
              <div><i>Teknik görüşme</i><b>Uygulama ve uyumluluk için teknik ekip</b></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Netlify Forms talep formu -->
      <aside class="ak-detail__side" style="position:static;">
        <div class="anda-panel">
          <div class="anda-panel__head"><span class="anda-panel__title">Talep Formu</span></div>
          <div class="anda-panel__body">
            <form name="talep" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/tesekkurler/" style="display:flex;flex-direction:column;gap:14px;">
              <input type="hidden" name="form-name" value="talep" />
              <p hidden><label>Boş bırakın: <input name="bot-field" /></label></p>

              <div class="anda-field">
                <label class="anda-field__label" for="firma"><span class="idx">01</span><span class="lt">Firma</span><span class="req" aria-hidden="true">●</span></label>
                <input class="anda-input" id="firma" name="firma" placeholder="Firma adı" required />
              </div>

              <div class="anda-field">
                <label class="anda-field__label" for="tip"><span class="idx">02</span><span class="lt">Talep tipi</span></label>
                <div class="anda-select-wrap">
                  <select class="anda-select" id="tip" name="talep_tipi">
                    <option value="Teklif">Teklif</option>
                    <option value="TDS / Katalog">TDS / Katalog</option>
                    <option value="SDS / GBF">SDS / GBF</option>
                    <option value="Teknik görüşme">Teknik görüşme</option>
                  </select>
                  <span class="chev"><Icon name="chevron-down" size={16} /></span>
                </div>
              </div>

              <div class="anda-field">
                <label class="anda-field__label" for="urun"><span class="idx">03</span><span class="lt">İlgilendiğiniz ürün</span></label>
                <input class="anda-input anda-input--mono" id="urun" name="urun" placeholder="ANDA PCE 150 WR" />
              </div>

              <div class="anda-field">
                <label class="anda-field__label" for="eposta"><span class="idx">04</span><span class="lt">E-posta</span><span class="req" aria-hidden="true">●</span></label>
                <input class="anda-input" id="eposta" name="eposta" type="email" placeholder="ad@firma.com" required />
              </div>

              <div class="anda-field">
                <label class="anda-field__label" for="not"><span class="idx">05</span><span class="lt">Notunuz</span></label>
                <textarea class="anda-textarea" id="not" name="not" placeholder="Çimento tipi, hedef beton sınıfı, döküm koşulları…"></textarea>
              </div>

              <button type="submit" class="anda-btn anda-btn--primary anda-btn--md anda-btn--full">
                <span>Talebi Gönder</span><Icon name="arrow-right" size={17} />
              </button>
              <p style="font-size:11.5px;color:var(--text-faint);font-family:var(--font-mono);letter-spacing:.04em;margin:0;">KVKK · veriler yalnız talebin değerlendirilmesi için kullanılır.</p>
            </form>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <script is:inline>
    (() => {
      const p = new URLSearchParams(location.search);
      const urun = p.get('urun'); const tip = p.get('tip');
      if (urun) { const el = document.getElementById('urun'); if (el) el.value = urun; }
      if (tip) { const el = document.getElementById('tip'); if (el) el.value = tip; }
    })();
  </script>
</Base>
